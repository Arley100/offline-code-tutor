# EvalForge / TutorBench Local — web app environment example
# Copy this file to `.env` and fill in real values. NEVER commit a real `.env`.

# --- Database (PostgreSQL via Prisma) ---
# Local Docker Compose example (adjust user/password/port/db name to your setup):
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5433/evalforge?schema=public"

# --- Auth (placeholders for the future Auth.js / NextAuth integration) ---
# Ticket 1 ships a demo placeholder auth only; these are reserved for later.
# Generate a real secret with: openssl rand -base64 32
AUTH_SECRET="replace-me-with-a-random-secret"
# Base URL of the app, used by Auth.js callbacks later.
AUTH_URL="http://localhost:3000"

# --- Demo placeholder auth (Ticket 1 only) ---
# The demo sign-in sets a non-secure cookie just to exercise route protection.
# This is NOT real authentication and must be replaced before any real use.
DEMO_SESSION_COOKIE="evalforge_demo_session"
